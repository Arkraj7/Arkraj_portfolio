<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Arkraj Biswas | Environmental Researcher & Policy Analyst</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700;900&family=Share+Tech+Mono&family=Exo+2:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}

:root{
  --bg:#050c07;
  --bg2:#0a1510;
  --bg3:#0f1e14;
  --surface:#111f16;
  --surface2:#172a1d;
  --accent:#3ddc84;
  --accent2:#64ffda;
  --accent3:#00b4d8;
  --text:#d4f0dc;
  --text2:#8fb89a;
  --text3:#5a7d63;
  --border:#1e3a27;
  --border2:#2a5238;
  --glow:rgba(61,220,132,0.15);
  --glow2:rgba(100,255,218,0.1);
  --red:#ff6b6b;
  --amber:#ffd166;
  --heading-font:'Orbitron',monospace;
  --body-font:'Share Tech Mono',monospace;
  --text-font:'Exo 2',sans-serif;
}

[data-theme="light"]{
  --bg:#f0f6f2;
  --bg2:#e4ede8;
  --bg3:#d8e8de;
  --surface:#ffffff;
  --surface2:#edf5f0;
  --accent:#0a7a3c;
  --accent2:#0a6e6e;
  --accent3:#0077a8;
  --text:#0a1a0f;
  --text2:#2d5a3d;
  --text3:#4a7a5a;
  --border:#c0daca;
  --border2:#9ac4ad;
  --glow:rgba(10,122,60,0.08);
  --glow2:rgba(10,110,110,0.06);
  --red:#c0392b;
  --amber:#d68910;
}

html{scroll-behavior:smooth}

body{
  font-family:var(--text-font);
  background:var(--bg);
  color:var(--text);
  min-height:100vh;
  transition:background 0.4s,color 0.4s;
  overflow-x:hidden;
}

/* ── CANVAS GRID ── */
#grid-canvas{
  position:fixed;
  top:0;left:0;
  width:100%;height:100%;
  pointer-events:none;
  z-index:0;
  opacity:0.18;
}
[data-theme="light"] #grid-canvas{opacity:0.06}

/* ── TOP BAR ── */
#topbar{
  position:fixed;top:0;left:0;right:0;
  z-index:1000;
  background:rgba(5,12,7,0.92);
  backdrop-filter:blur(12px);
  border-bottom:1px solid var(--border);
  display:flex;
  align-items:center;
  padding:0 2rem;
  height:52px;
  gap:1rem;
  transition:background 0.4s;
}
[data-theme="light"] #topbar{background:rgba(240,246,242,0.92)}

.tb-datetime{
  font-family:var(--body-font);
  font-size:11px;
  color:var(--accent);
  letter-spacing:0.08em;
  min-width:200px;
}

.tb-search-wrap{
  flex:1;
  max-width:380px;
  position:relative;
}
.tb-search-wrap input{
  width:100%;
  background:var(--surface);
  border:1px solid var(--border2);
  color:var(--text);
  font-family:var(--body-font);
  font-size:12px;
  padding:6px 36px 6px 14px;
  border-radius:3px;
  outline:none;
  transition:border-color 0.3s,box-shadow 0.3s;
}
.tb-search-wrap input:focus{
  border-color:var(--accent);
  box-shadow:0 0 0 2px var(--glow);
}
.tb-search-wrap input::placeholder{color:var(--text3)}
.search-icon{
  position:absolute;right:10px;top:50%;transform:translateY(-50%);
  font-size:12px;color:var(--text3);pointer-events:none;
}
#search-results{
  position:absolute;top:calc(100% + 6px);left:0;right:0;
  background:var(--surface2);
  border:1px solid var(--border2);
  border-radius:4px;
  max-height:300px;
  overflow-y:auto;
  display:none;
  z-index:200;
}
.sr-item{
  padding:10px 14px;
  font-size:12px;
  color:var(--text2);
  cursor:pointer;
  border-bottom:1px solid var(--border);
  transition:background 0.2s;
}
.sr-item:hover{background:var(--surface)}
.sr-item span{color:var(--accent);font-weight:600}

.tb-spacer{flex:1}

.theme-btn{
  background:none;
  border:1px solid var(--border2);
  color:var(--text2);
  font-family:var(--body-font);
  font-size:11px;
  padding:5px 14px;
  border-radius:3px;
  cursor:pointer;
  letter-spacing:0.05em;
  transition:all 0.3s;
}
.theme-btn:hover{border-color:var(--accent);color:var(--accent)}

/* ── NAV ── */
nav{
  position:fixed;top:52px;left:0;right:0;
  z-index:999;
  background:rgba(5,12,7,0.88);
  backdrop-filter:blur(10px);
  border-bottom:1px solid var(--border);
  display:flex;
  align-items:center;
  padding:0 2rem;
  height:48px;
  transition:background 0.4s;
}
[data-theme="light"] nav{background:rgba(240,246,242,0.88)}

.nav-logo{
  font-family:var(--heading-font);
  font-size:12px;
  font-weight:700;
  color:var(--accent);
  letter-spacing:0.15em;
  text-transform:uppercase;
  margin-right:2rem;
  white-space:nowrap;
}

.nav-links{
  display:flex;
  gap:0;
  list-style:none;
  overflow-x:auto;
}
.nav-links a{
  font-family:var(--body-font);
  font-size:11px;
  color:var(--text3);
  text-decoration:none;
  padding:0 14px;
  height:48px;
  display:flex;
  align-items:center;
  letter-spacing:0.08em;
  border-bottom:2px solid transparent;
  transition:color 0.3s,border-color 0.3s;
  white-space:nowrap;
}
.nav-links a:hover,.nav-links a.active{
  color:var(--accent);
  border-bottom-color:var(--accent);
}

/* ── MAIN LAYOUT ── */
main{
  position:relative;
  z-index:1;
  padding-top:100px;
}

section{
  padding:5rem 2rem;
  max-width:1280px;
  margin:0 auto;
}

.section-label{
  font-family:var(--body-font);
  font-size:11px;
  color:var(--accent);
  letter-spacing:0.2em;
  text-transform:uppercase;
  margin-bottom:0.5rem;
}
.section-title{
  font-family:var(--heading-font);
  font-size:clamp(1.4rem,3vw,2.2rem);
  font-weight:700;
  color:var(--text);
  margin-bottom:1rem;
  line-height:1.2;
}
.section-sub{
  font-family:var(--text-font);
  color:var(--text2);
  font-size:0.95rem;
  max-width:640px;
  line-height:1.7;
  margin-bottom:3rem;
}

hr.section-divider{
  border:none;
  border-top:1px solid var(--border);
  max-width:1280px;
  margin:0 auto;
}

/* ── HERO ── */
#home{
  min-height:calc(100vh - 100px);
  display:flex;
  flex-direction:column;
  justify-content:center;
  padding-top:6rem;
  max-width:1280px;
  margin:0 auto;
}

.hero-tag{
  font-family:var(--body-font);
  font-size:12px;
  color:var(--accent);
  letter-spacing:0.25em;
  text-transform:uppercase;
  margin-bottom:1.5rem;
  display:flex;
  align-items:center;
  gap:12px;
}
.hero-tag::before{
  content:'';
  display:block;
  width:40px;height:1px;
  background:var(--accent);
}

.hero-title{
  font-family:var(--heading-font);
  font-size:clamp(2rem,6vw,4.2rem);
  font-weight:900;
  line-height:1.05;
  margin-bottom:1.5rem;
  color:var(--text);
}
.hero-title .hl{color:var(--accent)}
.hero-title .hl2{color:var(--accent2)}

.hero-sub{
  font-family:var(--text-font);
  font-size:1.05rem;
  color:var(--text2);
  max-width:620px;
  line-height:1.8;
  margin-bottom:2.5rem;
}

.hero-badges{
  display:flex;
  flex-wrap:wrap;
  gap:10px;
  margin-bottom:3rem;
}
.badge{
  font-family:var(--body-font);
  font-size:10px;
  letter-spacing:0.1em;
  padding:5px 14px;
  border:1px solid var(--border2);
  color:var(--text3);
  border-radius:2px;
  text-transform:uppercase;
}
.badge.accent{border-color:var(--accent);color:var(--accent)}

.hero-ctas{
  display:flex;
  gap:1rem;
  flex-wrap:wrap;
}
.btn-primary{
  font-family:var(--heading-font);
  font-size:11px;
  letter-spacing:0.12em;
  text-transform:uppercase;
  padding:12px 28px;
  background:var(--accent);
  color:#050c07;
  border:none;
  cursor:pointer;
  border-radius:2px;
  text-decoration:none;
  display:inline-flex;
  align-items:center;
  gap:8px;
  font-weight:700;
  transition:all 0.3s;
}
.btn-primary:hover{background:var(--accent2);transform:translateY(-1px)}
.btn-outline{
  font-family:var(--heading-font);
  font-size:11px;
  letter-spacing:0.12em;
  text-transform:uppercase;
  padding:12px 28px;
  background:transparent;
  color:var(--accent);
  border:1px solid var(--accent);
  cursor:pointer;
  border-radius:2px;
  text-decoration:none;
  display:inline-flex;
  align-items:center;
  gap:8px;
  font-weight:600;
  transition:all 0.3s;
}
.btn-outline:hover{background:var(--glow)}

.hero-stats{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(140px,1fr));
  gap:1px;
  margin-top:4rem;
  border:1px solid var(--border);
  background:var(--border);
}
.hstat{
  background:var(--surface);
  padding:1.5rem;
}
.hstat-num{
  font-family:var(--heading-font);
  font-size:2rem;
  font-weight:700;
  color:var(--accent);
  line-height:1;
  margin-bottom:6px;
}
.hstat-label{
  font-family:var(--body-font);
  font-size:10px;
  letter-spacing:0.1em;
  color:var(--text3);
  text-transform:uppercase;
}

/* ── ABOUT ── */
.about-grid{
  display:grid;
  grid-template-columns:1fr 1.4fr;
  gap:4rem;
  align-items:start;
}
@media(max-width:800px){.about-grid{grid-template-columns:1fr}}

.about-card{
  background:var(--surface);
  border:1px solid var(--border);
  padding:2rem;
  border-radius:3px;
  position:relative;
  overflow:hidden;
}
.about-card::before{
  content:'';
  position:absolute;
  top:0;left:0;right:0;
  height:3px;
  background:linear-gradient(90deg,var(--accent),var(--accent2));
}
.about-avatar{
  width:80px;height:80px;
  background:var(--surface2);
  border:2px solid var(--accent);
  border-radius:3px;
  display:flex;
  align-items:center;
  justify-content:center;
  font-family:var(--heading-font);
  font-size:1.8rem;
  color:var(--accent);
  margin-bottom:1.5rem;
}
.about-name{
  font-family:var(--heading-font);
  font-size:1.1rem;
  font-weight:700;
  color:var(--text);
  margin-bottom:4px;
}
.about-role{
  font-family:var(--body-font);
  font-size:11px;
  color:var(--accent);
  letter-spacing:0.1em;
  margin-bottom:1.5rem;
}
.about-info-row{
  display:flex;
  gap:10px;
  font-size:12px;
  color:var(--text2);
  margin-bottom:8px;
  font-family:var(--body-font);
}
.about-info-row .lbl{color:var(--text3);width:80px;flex-shrink:0}

.skills-list{
  display:flex;
  flex-wrap:wrap;
  gap:8px;
  margin-top:1.5rem;
}
.skill-tag{
  font-family:var(--body-font);
  font-size:10px;
  padding:4px 10px;
  border:1px solid var(--border2);
  color:var(--text2);
  border-radius:2px;
  letter-spacing:0.05em;
}

.about-content p{
  color:var(--text2);
  line-height:1.8;
  margin-bottom:1rem;
  font-size:0.95rem;
}
.about-content h3{
  font-family:var(--heading-font);
  font-size:0.85rem;
  color:var(--accent2);
  letter-spacing:0.15em;
  text-transform:uppercase;
  margin:2rem 0 1rem;
}

.timeline{
  position:relative;
  padding-left:1.5rem;
}
.timeline::before{
  content:'';
  position:absolute;left:4px;top:0;bottom:0;
  width:1px;background:var(--border2);
}
.tl-item{
  position:relative;
  margin-bottom:1.5rem;
}
.tl-item::before{
  content:'';
  position:absolute;left:-20px;top:6px;
  width:8px;height:8px;
  border:1px solid var(--accent);
  background:var(--bg);
  border-radius:50%;
}
.tl-year{
  font-family:var(--body-font);
  font-size:10px;
  color:var(--accent);
  letter-spacing:0.1em;
  margin-bottom:3px;
}
.tl-title{
  font-family:var(--text-font);
  font-weight:600;
  font-size:0.9rem;
  color:var(--text);
  margin-bottom:3px;
}
.tl-desc{
  font-size:0.82rem;
  color:var(--text3);
}

/* ── RESEARCH TOPICS ── */
.topics-grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(280px,1fr));
  gap:1rem;
}
.topic-card{
  background:var(--surface);
  border:1px solid var(--border);
  padding:1.5rem;
  border-radius:3px;
  cursor:pointer;
  transition:border-color 0.3s,transform 0.3s;
  position:relative;
  overflow:hidden;
}
.topic-card::after{
  content:'';
  position:absolute;
  bottom:0;left:0;right:0;
  height:2px;
  background:linear-gradient(90deg,transparent,var(--accent),transparent);
  transform:scaleX(0);
  transition:transform 0.3s;
}
.topic-card:hover{border-color:var(--border2);transform:translateY(-2px)}
.topic-card:hover::after{transform:scaleX(1)}

.topic-icon{
  font-size:1.8rem;
  margin-bottom:1rem;
}
.topic-title{
  font-family:var(--heading-font);
  font-size:0.8rem;
  font-weight:700;
  color:var(--accent);
  letter-spacing:0.1em;
  text-transform:uppercase;
  margin-bottom:0.5rem;
}
.topic-desc{
  font-size:0.85rem;
  color:var(--text2);
  line-height:1.6;
}

/* ── ENCYCLOPEDIA ── */
.enc-categories{
  display:flex;
  gap:8px;
  flex-wrap:wrap;
  margin-bottom:2rem;
}
.cat-btn{
  font-family:var(--body-font);
  font-size:11px;
  padding:6px 16px;
  border:1px solid var(--border2);
  background:transparent;
  color:var(--text3);
  cursor:pointer;
  border-radius:2px;
  letter-spacing:0.08em;
  transition:all 0.3s;
}
.cat-btn.active,.cat-btn:hover{
  border-color:var(--accent);
  color:var(--accent);
  background:var(--glow);
}

.enc-grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(300px,1fr));
  gap:1.5rem;
}
.enc-card{
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:3px;
  overflow:hidden;
  transition:border-color 0.3s;
}
.enc-card:hover{border-color:var(--border2)}
.enc-card-header{
  background:var(--surface2);
  padding:1rem 1.5rem;
  border-bottom:1px solid var(--border);
  display:flex;
  align-items:center;
  gap:10px;
}
.enc-cat-tag{
  font-family:var(--body-font);
  font-size:9px;
  letter-spacing:0.15em;
  text-transform:uppercase;
  padding:2px 8px;
  border-radius:2px;
  border:1px solid currentColor;
}
.enc-card-body{padding:1.5rem}
.enc-title{
  font-family:var(--heading-font);
  font-size:0.85rem;
  color:var(--text);
  margin-bottom:0.5rem;
}
.enc-excerpt{
  font-size:0.82rem;
  color:var(--text2);
  line-height:1.6;
  margin-bottom:1rem;
}
.enc-read-more{
  font-family:var(--body-font);
  font-size:10px;
  color:var(--accent);
  letter-spacing:0.1em;
  text-decoration:none;
  display:inline-flex;
  align-items:center;
  gap:6px;
  cursor:pointer;
  background:none;
  border:none;
}

/* ── INFOGRAPHICS ── */
.infog-grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(340px,1fr));
  gap:1.5rem;
}
.infog-slot{
  background:var(--surface);
  border:1px dashed var(--border2);
  border-radius:4px;
  min-height:280px;
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  text-align:center;
  padding:2rem;
  position:relative;
  transition:border-color 0.3s;
}
.infog-slot:hover{border-color:var(--accent)}
.infog-slot.has-content{
  border-style:solid;
  border-color:var(--border);
  align-items:stretch;
  justify-content:flex-start;
}
.infog-placeholder-icon{font-size:2.5rem;margin-bottom:1rem;opacity:0.4}
.infog-placeholder-text{
  font-family:var(--body-font);
  font-size:11px;
  color:var(--text3);
  letter-spacing:0.08em;
  text-align:center;
}
.infog-title-bar{
  font-family:var(--heading-font);
  font-size:0.75rem;
  color:var(--accent2);
  letter-spacing:0.1em;
  text-transform:uppercase;
  margin-bottom:1rem;
  padding-bottom:0.75rem;
  border-bottom:1px solid var(--border);
}

/* sample infographic chart */
.bar-chart{width:100%}
.bar-row{
  display:flex;
  align-items:center;
  gap:10px;
  margin-bottom:10px;
  font-size:11px;
  font-family:var(--body-font);
}
.bar-label{color:var(--text2);width:100px;font-size:10px;flex-shrink:0}
.bar-track{flex:1;background:var(--bg3);height:22px;border-radius:2px;overflow:hidden}
.bar-fill{
  height:100%;
  display:flex;
  align-items:center;
  padding-left:8px;
  font-size:10px;
  font-weight:600;
  color:#050c07;
  border-radius:2px;
  transition:width 1.5s ease;
}

/* ── ARTICLES ── */
.articles-grid{
  display:grid;
  grid-template-columns:2fr 1fr;
  gap:2rem;
}
@media(max-width:900px){.articles-grid{grid-template-columns:1fr}}

.article-featured{
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:3px;
  overflow:hidden;
}
.article-featured-header{
  background:var(--surface2);
  padding:1.5rem;
  border-bottom:1px solid var(--border);
}
.article-meta{
  display:flex;
  gap:12px;
  font-family:var(--body-font);
  font-size:10px;
  color:var(--text3);
  letter-spacing:0.08em;
  margin-bottom:0.75rem;
}
.article-cat{color:var(--accent)}
.article-title{
  font-family:var(--heading-font);
  font-size:1rem;
  color:var(--text);
  line-height:1.3;
  margin-bottom:0.5rem;
}
.article-excerpt{
  font-size:0.88rem;
  color:var(--text2);
  line-height:1.7;
}
.article-body{padding:1.5rem}

.article-list{
  display:flex;
  flex-direction:column;
  gap:1rem;
}
.article-mini{
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:3px;
  padding:1.2rem;
  transition:border-color 0.3s;
  cursor:pointer;
}
.article-mini:hover{border-color:var(--border2)}
.article-mini-title{
  font-family:var(--heading-font);
  font-size:0.78rem;
  color:var(--text);
  margin-bottom:0.4rem;
  line-height:1.3;
}
.article-mini-meta{
  font-family:var(--body-font);
  font-size:10px;
  color:var(--text3);
  letter-spacing:0.06em;
}

/* ── COLLABORATE ── */
.collab-wrap{
  display:grid;
  grid-template-columns:1fr 1.2fr;
  gap:4rem;
  align-items:start;
}
@media(max-width:800px){.collab-wrap{grid-template-columns:1fr}}

.collab-info h3{
  font-family:var(--heading-font);
  font-size:0.8rem;
  color:var(--accent2);
  letter-spacing:0.15em;
  text-transform:uppercase;
  margin-bottom:1rem;
}
.collab-info ul{
  list-style:none;
  display:flex;
  flex-direction:column;
  gap:12px;
}
.collab-info li{
  display:flex;
  gap:12px;
  font-size:0.88rem;
  color:var(--text2);
  line-height:1.5;
}
.collab-info li::before{
  content:'→';
  color:var(--accent);
  font-family:var(--body-font);
  flex-shrink:0;
  margin-top:2px;
}

.form-card{
  background:var(--surface);
  border:1px solid var(--border);
